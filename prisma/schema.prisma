generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  // Personal Access Token do Figma, criptografado em repouso (por usuário).
  figmaAccessToken String?
  createdAt    DateTime @default(now())
  studies      Study[]
  projects     Project[]
}

model Project {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  studies   Study[]
}

model Study {
  id         String      @id @default(cuid())
  ownerId    String
  owner      User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projectId  String
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  status     StudyStatus @default(draft)
  deviceType DeviceType  @default(desktop)
  language   Language    @default(pt)
  // Boas-vindas customizáveis do testador (nulo = usa o padrão do idioma)
  welcomeTitle   String?
  welcomeMessage String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  prototype  Prototype?
  blocks     Block[]
  sessions   Session[]
}

enum StudyStatus {
  draft
  live
  closed
}

model Prototype {
  id           String          @id @default(cuid())
  studyId      String          @unique
  study        Study           @relation(fields: [studyId], references: [id], onDelete: Cascade)
  source       PrototypeSource
  figmaFileKey String?
  createdAt    DateTime        @default(now())
  screens      Screen[]
}

enum PrototypeSource {
  image
  figma
}

enum DeviceType {
  desktop
  tablet
  mobile
}

enum Language {
  pt
  es
}

enum ScrollMode {
  none
  vertical
  horizontal
  both
}

enum ScrollAxis {
  horizontal
  vertical
  both
}

enum RegionKind {
  scroll // faixa rolável (precisa de uma tira com o conteúdo completo)
  fixed // faixa fixa (topo/rodapé) reaproveitando a própria tela
}

model ScrollRegion {
  id        String     @id @default(cuid())
  screenId  String
  screen    Screen     @relation(fields: [screenId], references: [id], onDelete: Cascade)
  kind      RegionKind @default(scroll)
  coords    Json // {x,y,w,h} normalizado sobre a tela base
  axis      ScrollAxis @default(horizontal)
  imageUrl  String? // tira (só para kind=scroll); fixed reaproveita a imagem da tela
  createdAt DateTime   @default(now())
}

model Screen {
  id               String         @id @default(cuid())
  prototypeId      String
  prototype        Prototype      @relation(fields: [prototypeId], references: [id], onDelete: Cascade)
  name             String
  order            Int
  imageUrl         String
  width            Float
  height           Float
  scroll           ScrollMode     @default(none)
  scrollRegions    ScrollRegion[]
  hotspots         Hotspot[]      @relation("ScreenHotspots")
  incomingHotspots Hotspot[]     @relation("HotspotTarget")
  missionStarts    Mission[]     @relation("MissionStartScreen")
  missionGoals     MissionGoal[]
  pathSteps        PathStep[]
  events           Event[]       @relation("EventScreen")
  targetedByEvents Event[]       @relation("EventTargetScreen")
}

enum HotspotShape {
  rect
  polygon
}

enum HotspotAction {
  navigate
  open_overlay
  close_overlay
  back
}

enum OverlayPosition {
  bottom
  center
}

model Hotspot {
  id              String           @id @default(cuid())
  screenId        String
  screen          Screen           @relation("ScreenHotspots", fields: [screenId], references: [id], onDelete: Cascade)
  shape           HotspotShape
  coords          Json
  action          HotspotAction    @default(navigate)
  overlayPosition OverlayPosition?
  targetScreenId  String?
  targetScreen    Screen?          @relation("HotspotTarget", fields: [targetScreenId], references: [id])
  events          Event[]
}

model Block {
  id       String    @id @default(cuid())
  studyId  String
  study    Study     @relation(fields: [studyId], references: [id], onDelete: Cascade)
  type     BlockType
  order    Int
  mission  Mission?
  question Question?
}

enum BlockType {
  mission
  question
}

enum QuestionType {
  open // resposta aberta (texto)
  choice // múltipla escolha (uma opção)
  rating // estrelas 1..5
  binary // sim/não
}

// Pergunta pertence a UM Block (geral/solta na sequência) OU a uma Mission
// (pergunta de acompanhamento, respondida logo após a tarefa).
model Question {
  id          String       @id @default(cuid())
  blockId     String?      @unique
  block       Block?       @relation(fields: [blockId], references: [id], onDelete: Cascade)
  missionId   String?
  mission     Mission?     @relation(fields: [missionId], references: [id], onDelete: Cascade)
  order       Int          @default(0) // ordem dentro da missão
  type        QuestionType
  title       String
  description String?
  required    Boolean      @default(true)
  options     Json? // choice: string[]
  answers     Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String? // open
  choice     String? // choice (opção) ou binary ("yes"/"no")
  rating     Int? // rating 1..5
  createdAt  DateTime @default(now())

  @@unique([sessionId, questionId])
}

model Mission {
  id            String          @id @default(cuid())
  blockId       String          @unique
  block         Block           @relation(fields: [blockId], references: [id], onDelete: Cascade)
  task          String
  description   String?
  startScreenId String
  startScreen   Screen          @relation("MissionStartScreen", fields: [startScreenId], references: [id])
  successType   SuccessType
  goals         MissionGoal[]
  paths         MissionPath[]
  results       MissionResult[]
  events        Event[]
  questions     Question[]
}

enum SuccessType {
  screen
  path
}

model MissionGoal {
  id           String  @id @default(cuid())
  missionId    String
  mission      Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  goalScreenId String
  goalScreen   Screen  @relation(fields: [goalScreenId], references: [id])
}

model MissionPath {
  id        String     @id @default(cuid())
  missionId String
  mission   Mission    @relation(fields: [missionId], references: [id], onDelete: Cascade)
  label     String
  steps     PathStep[]
}

model PathStep {
  id            String      @id @default(cuid())
  missionPathId String
  missionPath   MissionPath @relation(fields: [missionPathId], references: [id], onDelete: Cascade)
  screenId      String
  screen        Screen      @relation(fields: [screenId], references: [id])
  order         Int
}

model Session {
  id         String          @id @default(cuid())
  studyId    String
  study      Study           @relation(fields: [studyId], references: [id], onDelete: Cascade)
  token      String          @unique @default(cuid())
  startedAt  DateTime        @default(now())
  finishedAt DateTime?
  userAgent  String?
  deviceType String?
  results    MissionResult[]
  events     Event[]
  answers    Answer[]
}

enum MissionOutcome {
  direct
  indirect
  unfinished
  given_up
}

model MissionResult {
  id            String         @id @default(cuid())
  sessionId     String
  session       Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  missionId     String
  mission       Mission        @relation(fields: [missionId], references: [id], onDelete: Cascade)
  outcome       MissionOutcome
  durationMs    Int
  misclickCount Int
  clickCount    Int
}

enum EventType {
  click
  navigate
  misclick
  give_up
  end
}

model Event {
  id             String    @id @default(cuid())
  sessionId      String
  session        Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  missionId      String
  mission        Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  screenId       String
  screen         Screen    @relation("EventScreen", fields: [screenId], references: [id])
  type           EventType
  xNorm          Float
  yNorm          Float
  hotspotId      String?
  hotspot        Hotspot?  @relation(fields: [hotspotId], references: [id])
  targetScreenId String?
  targetScreen   Screen?   @relation("EventTargetScreen", fields: [targetScreenId], references: [id])
  timestampMs    BigInt
}
